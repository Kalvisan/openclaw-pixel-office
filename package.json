{
  "name": "openclaw-pixel-office",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev --parallel",
    "dev:site": "pnpm --filter site dev",
    "dev:runtime": "pnpm --filter runtime dev",
    "lint": "pnpm -r run lint",
    "generate-officemap": "tsx scripts/generate-officemap.mts",
    "stitch-modern-office": "node scripts/stitch-modern-office.mjs",
    "setup-office-assets": "node scripts/setup-office-assets.mjs",
    "dev:office-viewer": "pnpm --filter office-viewer dev"
  },
  "devDependencies": {
    "@openclaw-office/zipgen": "workspace:*",
    "sharp": "^0.33.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
